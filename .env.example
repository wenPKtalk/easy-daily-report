# Easy Daily Report - 环境变量配置示例
# 复制此文件为 .env 并填入你的实际值

# =============================================================================
# LLM 配置 (必需)
# =============================================================================

# LLM 提供商类型
# 可选值: openai-compatible (默认), ollama
LLM_PROVIDER=openai-compatible

# API 基础地址
# ZhipuAI: https://open.bigmodel.cn/api/paas/v4/
# OpenAI: https://api.openai.com/v1
# Ollama: http://localhost:11434/v1
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# API 密钥
# - ZhipuAI: 从 https://open.bigmodel.cn/ 获取
# - OpenAI: 从 https://platform.openai.com/api-keys 获取
# - Ollama: 无需密钥，保持为空或填 "ollama"
OPENAI_API_KEY=your-api-key-here

# LLM 模型名称
# ZhipuAI: glm-4-flash (免费), glm-4, glm-4-plus
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
# Ollama: llama3, mistral, qwen2 等本地模型
LLM_MODEL=glm-4-flash

# 生成温度 (0.0 - 2.0, 默认 0.3)
# 越低越严谨，越高越创造性
LLM_TEMPERATURE=0.3

# 最大生成令牌数 (默认 2000)
# LLM_MAX_TOKENS=2000

# 请求超时时间（秒，默认 60）
# LLM_TIMEOUT=60

# 是否记录请求/响应日志 (默认 true)
# LLM_LOG_REQUESTS=true
# LLM_LOG_RESPONSES=true


# =============================================================================
# Ollama 本地模型配置示例 (如果使用 Ollama)
# =============================================================================
# 取消下方注释并注释上方配置即可切换到本地模型
#
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# LLM_MODEL=llama3
# LLM_TEMPERATURE=0.3

# =============================================================================
# PGVector 向量数据库配置 (可选，默认本地 Docker)
# =============================================================================

PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DATABASE=daily_report
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=postgres

# =============================================================================
# Jira 集成配置 (可选，不配置则无法使用 Jira 功能)
# =============================================================================

# Jira 实例地址 (例如: https://yourcompany.atlassian.net)
JIRA_BASE_URL=https://your-domain.atlassian.net

# Jira 用户名 (邮箱)
JIRA_USERNAME=your-email@example.com

# Jira API Token (从 https://id.atlassian.com/manage-profile/security/api-tokens 获取)
JIRA_API_TOKEN=your-jira-api-token

# =============================================================================
# Git 配置 (可选)
# =============================================================================

# 默认 Git 仓库路径 (相对或绝对路径)
GIT_REPO_PATH=./

# =============================================================================
# 示例配置组合
# =============================================================================

# 开发环境最小配置 (仅 LLM + 本地 PGVector)
# OPENAI_API_KEY=sk-xxx

# 完整功能配置 (LLM + PGVector + Jira)
# OPENAI_API_KEY=sk-xxx
# JIRA_BASE_URL=https://company.atlassian.net
# JIRA_USERNAME=dev@company.com
# JIRA_API_TOKEN=xxx
